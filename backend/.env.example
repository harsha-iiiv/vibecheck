# Gemini
GOOGLE_API_KEY=your_gemini_api_key

# Mistral (fallback LLM when Gemini quota exhausted)
MISTRAL_API_KEY=your_mistral_api_key

# YouTube Music RapidAPI
RAPIDAPI_KEY=your_rapidapi_key

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_MOOD_VOICE_ID=voice_id_mood
ELEVENLABS_DJ_VOICE_ID=voice_id_dj
ELEVENLABS_CROWD_VOICE_ID=voice_id_crowd
ELEVENLABS_VISUAL_VOICE_ID=voice_id_visual
ELEVENLABS_SOCIAL_VOICE_ID=voice_id_social

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/vibecheck

# fetch.ai agent seeds (any random phrase — used as deterministic wallet)
FETCHAI_AGENT_SEED_MOOD=mood_agent_seed_phrase_change_me
FETCHAI_AGENT_SEED_DJ=dj_agent_seed_phrase_change_me
FETCHAI_AGENT_SEED_CROWD=crowd_agent_seed_phrase_change_me
FETCHAI_AGENT_SEED_VISUAL=visual_agent_seed_phrase_change_me
FETCHAI_AGENT_SEED_SOCIAL=social_agent_seed_phrase_change_me

# Server
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Vultr (deployment reference)
VULTR_API_KEY=your_vultr_key
